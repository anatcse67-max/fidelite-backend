{
  "permissions": {
    "allow": [
      "Bash(git --version)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git rm *)",
      "Bash(git config *)",
      "Bash(npm install *)",
      "Bash(New-Item -ItemType File -Path \".env\" -Force)",
      "Bash(Out-Null)",
      "Bash(Set-Content \".env\" -Encoding utf8 \"SUPABASE_URL=`nSUPABASE_SERVICE_KEY=`nJWT_SECRET=`nPORT=3000\")",
      "Bash(r)",
      "Bash(Set-Content -Path \".env\" -Value \"SUPABASE_URL=`r`nSUPABASE_SERVICE_KEY=`r`nJWT_SECRET=`r`nPORT=3000\" -Encoding utf8)",
      "Bash(timeout 5 node server.js)",
      "Bash(node -e \"console.log\\(require\\('crypto'\\).randomBytes\\(48\\).toString\\('hex'\\)\\)\")"
    ]
  }
}
